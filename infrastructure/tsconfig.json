{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "outDir": "./",
    "inlineSourceMap": true,
    "inlineSources": true,
    "esModuleInterop": true,
    "typeRoots": ["./node_modules/@types"],
    "experimentalDecorators": true
  },
  "exclude": ["node_modules", "cdk.out"]
}
